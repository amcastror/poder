---
layout: base.njk
title: "PODER | SaaS en la era de la IA"
description: "Una presentacion web estatica sobre como competir como empresa SaaS en la era de la IA."
---

<main class="deck" id="inicio">
  {% for slide in slides %}
    <section class="slide slide--{{ slide.theme }}" id="slide-{{ loop.index }}" aria-labelledby="slide-title-{{ loop.index }}">
      <div class="slide__grid{% if not slide.image %} slide__grid--solo{% endif %}">
        <div class="slide__copy reveal">
          <p class="eyebrow">{{ loop.index0 | pad2 }} / {{ slide.eyebrow }}</p>
          <h1 id="slide-title-{{ loop.index }}">{{ slide.title }}</h1>
          <p class="lead">{{ slide.lead }}</p>

          {% if slide.body %}
            <p class="body-copy">{{ slide.body }}</p>
          {% endif %}

          {% if slide.signal %}
            <p class="signal">{{ slide.signal }}</p>
          {% endif %}

          {% if slide.points %}
            <ol class="axis-list">
              {% for point in slide.points %}
                <li>
                  <span>{{ point.label }}</span>
                  <small>{{ point.text }}</small>
                </li>
              {% endfor %}
            </ol>
          {% elif slide.framework %}
            <div class="poder-map">
              {% for item in slide.framework %}
                <div class="poder-row">
                  <strong>{{ item[0] }}</strong>
                  <span>{{ item[1] }}</span>
                  <small>{{ item[2] }}</small>
                </div>
              {% endfor %}
            </div>
          {% elif slide.contrast %}
            <div class="before-after">
              <div>
                <span>Antes</span>
                <p>{{ slide.contrast.before }}</p>
              </div>
              <div>
                <span>Despues</span>
                <p>{{ slide.contrast.after }}</p>
              </div>
            </div>
          {% endif %}

          {% if slide.question %}
            <p class="slide-question">{{ slide.question }}</p>
          {% endif %}
        </div>

        {% if slide.image %}
          <figure class="slide__visual reveal">
            <img src="{{ slide.image | url }}" alt="{{ slide.imageAlt }}">
          </figure>
        {% endif %}
      </div>
    </section>
  {% endfor %}
</main>

<section class="references-section" id="referencias" aria-labelledby="references-title">
  <div class="references-section__inner reveal">
    <div class="references-section__header">
      <p class="eyebrow">Fuentes</p>
      <h2 id="references-title">Referencias</h2>
      <p>Material base y contexto usado para construir la sintesis de la presentacion.</p>
    </div>

    <div class="references-list" aria-label="Referencias por seccion">
      {% for group in references %}
        <section class="reference-group" aria-labelledby="reference-group-{{ loop.index }}">
          <h3 id="reference-group-{{ loop.index }}">{{ group.section }}</h3>

          <ul>
            {% for item in group.items %}
              <li>
                <div>
                  <strong>{{ item.source }}</strong>
                  <span>{{ item.type }}</span>
                </div>

                {% if item.link.url %}
                  <a href="{{ item.link.url }}" rel="noreferrer" target="_blank">{{ item.link.label }}</a>
                {% else %}
                  <span>{{ item.link.label }}</span>
                {% endif %}

                <small>{{ item.contribution }}</small>
              </li>
            {% endfor %}
          </ul>
        </section>
      {% endfor %}
    </div>
  </div>
</section>
